# Optional local build overrides.
# Copy this file to .build.env and edit it for your machine.
# .build.env is ignored by Git.

# Direct MSBuild path. Use this when auto-detection does not find Build Tools.
# CSEND_MSBUILD=C:\Program Files\Microsoft Visual Studio\2022\BuildTools\MSBuild\Current\Bin\MSBuild.exe

# Visual Studio / Build Tools install directory. Used to derive MSBuild.exe.
# CSEND_VS_INSTALL=C:\Program Files\Microsoft Visual Studio\2022\BuildTools

# Optional custom vswhere path.
# CSEND_VSWHERE=C:\Program Files (x86)\Microsoft Visual Studio\Installer\vswhere.exe

# Optional temp directory for MSBuild.
# CSEND_BUILD_TEMP=C:\path\to\writable\temp

# Optional clean PATH passed only to MSBuild child processes.
# Use this if your build environment needs extra command-line tools.
# CSEND_BUILD_PATH=C:\Windows\System32;C:\Windows;C:\Windows\System32\Wbem
